<Window x:Class="ByleAdministration.Vistas.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="ByleAdministration — Login"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="14" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.5"/>
                <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- PANEL IZQUIERDO — branding -->
            <Border Grid.Column="0" CornerRadius="14,0,0,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource secondaryBackColor1}" Offset="0"/>
                        <GradientStop Color="{StaticResource secondaryBackColor2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Barra control -->
                    <StackPanel Orientation="Horizontal"
                                FlowDirection="RightToLeft"
                                VerticalAlignment="Top"
                                Margin="0,8,10,0">
                        <Button Style="{StaticResource controlButton}"
                                Click="BtnCerrar_Click">
                            <fa:IconImage Icon="Xmark" Width="11" Height="11"
                                          Foreground="{DynamicResource BrushTextMuted}"/>
                        </Button>
                    </StackPanel>

                    <!-- Contenido centrado -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="40,0">

                        <!-- Logo — sin LetterSpacing (no compatible con .NET 4.8) -->
                        <TextBlock Text="B Y L E"
                                   FontSize="52" FontWeight="Black"
                                   Foreground="{DynamicResource BrushAccent}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="A D M I N I S T R A T I O N"
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,32"/>

                        <!-- Separador decorativo -->
                        <Rectangle Height="2" Width="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,28">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="{StaticResource color1}" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Features -->
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="{DynamicResource BrushAccentMuted}"
                                        Margin="0,0,12,0">
                                    <fa:IconImage Icon="DoorOpen" Width="14" Height="14"
                                                  Foreground="{DynamicResource BrushAccent}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Control de acceso"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <TextBlock Text="Registro biométrico en tiempo real"
                                               FontSize="10"
                                               Foreground="{DynamicResource BrushTextMuted}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="{DynamicResource BrushAccentMuted}"
                                        Margin="0,0,12,0">
                                    <fa:IconImage Icon="CashRegister" Width="14" Height="14"
                                                  Foreground="{DynamicResource BrushAccent}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Punto de venta"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <TextBlock Text="Membresías, clases y productos"
                                               FontSize="10"
                                               Foreground="{DynamicResource BrushTextMuted}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="8"
                                        Background="{DynamicResource BrushAccentMuted}"
                                        Margin="0,0,12,0">
                                    <fa:IconImage Icon="ChartBar" Width="14" Height="14"
                                                  Foreground="{DynamicResource BrushAccent}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Reportes y métricas"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <TextBlock Text="Estadísticas del gimnasio"
                                               FontSize="10"
                                               Foreground="{DynamicResource BrushTextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PANEL DERECHO — formulario -->
            <Border Grid.Column="1" CornerRadius="0,14,14,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0"/>
                        <GradientStop Color="{StaticResource primaryBackColor2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel VerticalAlignment="Center" Margin="36,0">

                    <TextBlock Text="Bienvenido"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Inicia sesión para continuar"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,28"/>

                    <!-- Correo -->
                    <TextBlock Text="Correo" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BrushBgInput}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="Envelope" Width="14" Height="14"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCorreo" Grid.Column="1"
                                     Height="40" BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     CaretBrush="{DynamicResource BrushAccent}"
                                     FontSize="13" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Contraseña -->
                    <TextBlock Text="Contraseña" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BrushBgInput}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="Lock" Width="14" Height="14"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            <PasswordBox x:Name="PbxContrasena" Grid.Column="1"
                                         Height="40" BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         FontSize="13" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Botón ingresar -->
                    <Button x:Name="BtnIngresar"
                            Height="42"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnIngresar_Click"
                            Margin="0,0,0,14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F26419" Offset="0"/>
                                            <GradientStop Color="#D94F00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <fa:IconImage Icon="RightToBracket" Width="14" Height="14"
                                                      Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="INGRESAR" FontSize="13"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Link registro -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="¿Nuevo empleado? "
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"/>
                        <TextBlock FontSize="11" Cursor="Hand">
                            <Hyperlink x:Name="LnkRegistro"
                                       Click="LnkRegistro_Click"
                                       Foreground="{DynamicResource BrushAccent}">
                                Registrar cuenta
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>