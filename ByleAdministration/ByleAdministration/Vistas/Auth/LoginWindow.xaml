<Window x:Class="ByleAdministration.Vistas.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ByleAdministration — Login"
        Height="420" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BrushOscuro}">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo / Título -->
        <TextBlock Grid.Row="0"
                   Text="BYLE"
                   FontSize="32" FontWeight="Bold"
                   Foreground="{StaticResource BrushNaranja}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   Text="Administration"
                   FontSize="13"
                   Foreground="{StaticResource BrushTextoClaro}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,28"/>

        <!-- Correo -->
        <TextBlock Grid.Row="2"
                   Text="Correo"
                   Foreground="{StaticResource BrushTextoClaro}"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="TxtCorreo"
                 Grid.Row="3"
                 Height="34" Padding="8,6"
                 Margin="0,0,0,14"/>

        <!-- Contraseña -->
        <TextBlock Grid.Row="4"
                   Text="Contraseña"
                   Foreground="{StaticResource BrushTextoClaro}"
                   Margin="0,0,0,4"/>
        <PasswordBox x:Name="PbxContrasena"
                     Grid.Row="5"
                     Height="34" Padding="8,6"
                     Margin="0,0,0,24"/>

        <!-- Botón ingresar -->
        <Button Grid.Row="6"
                x:Name="BtnIngresar"
                Content="INGRESAR"
                Height="38"
                Background="{StaticResource BrushNaranja}"
                Foreground="White"
                FontWeight="Bold"
                BorderThickness="0"
                Margin="0,0,0,10"
                Click="BtnIngresar_Click"/>

        <!-- Link a registro -->
        <TextBlock Grid.Row="7"
                   HorizontalAlignment="Center">
            <Hyperlink x:Name="LnkRegistro" Click="LnkRegistro_Click">
                Registrar nuevo empleado
            </Hyperlink>
        </TextBlock>

    </Grid>
</Window>