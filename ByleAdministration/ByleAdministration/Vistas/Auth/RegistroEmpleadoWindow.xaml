<Window x:Class="ByleAdministration.Vistas.Auth.RegistroEmpleadoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Registrar Empleado"
        Height="640" Width="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="14" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.5"/>
                <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource primaryBackColor2}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Barra control -->
            <StackPanel Orientation="Horizontal"
                        FlowDirection="RightToLeft"
                        VerticalAlignment="Top"
                        Margin="0,8,10,0">
                <Button Style="{StaticResource controlButton}"
                        Click="BtnCerrar_Click">
                    <fa:IconImage Icon="Xmark" Width="11" Height="11"
                                  Foreground="{DynamicResource BrushTextMuted}"/>
                </Button>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,28,0,0">
                <StackPanel Margin="36,16,36,36">

                    <!-- Header -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Nuevo empleado"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Completa los datos para crear la cuenta"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrushTextSecondary}"/>
                        <Rectangle Height="2" Width="40" HorizontalAlignment="Left"
                                   Margin="0,12,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{StaticResource color1}" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>

                    <!-- Campo helper style inline -->
                    <!-- Nombre -->
                    <TextBlock Text="Nombre completo" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BrushBgInput}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="User" Width="13" Height="13"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtNombre" Grid.Column="1"
                                     Height="38" BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     CaretBrush="{DynamicResource BrushAccent}"
                                     FontSize="12" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Correo -->
                    <TextBlock Text="Correo" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BrushBgInput}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="Envelope" Width="13" Height="13"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCorreo" Grid.Column="1"
                                     Height="38" BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     CaretBrush="{DynamicResource BrushAccent}"
                                     FontSize="12" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Teléfono + RFC en fila -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Teléfono" FontSize="11"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource BrushBgInput}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconImage Icon="Phone" Width="12" Height="12"
                                                  Foreground="{DynamicResource BrushTextMuted}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="TxtTelefono" Grid.Column="1"
                                             Height="38" BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource BrushTextPrimary}"
                                             CaretBrush="{DynamicResource BrushAccent}"
                                             FontSize="12" VerticalContentAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="RFC" FontSize="11"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource BrushBgInput}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconImage Icon="IdCard" Width="12" Height="12"
                                                  Foreground="{DynamicResource BrushTextMuted}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox x:Name="TxtRfc" Grid.Column="1"
                                             Height="38" BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource BrushTextPrimary}"
                                             CaretBrush="{DynamicResource BrushAccent}"
                                             FontSize="12" VerticalContentAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Rol -->
                    <TextBlock Text="Rol" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BrushBgInput}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="ShieldHalved" Width="13" Height="13"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbRol" Grid.Column="1"
                                      Height="38" BorderThickness="0"
                                      Background="Transparent"
                                      Foreground="{DynamicResource BrushTextPrimary}"
                                      FontSize="12" VerticalContentAlignment="Center"
                                      ItemsSource="{Binding Roles}"
                                      SelectedItem="{Binding RolSeleccionado}"
                                      DisplayMemberPath="NombreRol"
                                      SelectedValuePath="IdRol"/>
                        </Grid>
                    </Border>

                    <!-- Contraseña -->
                    <TextBlock Text="Contraseña" FontSize="11"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               Margin="0,0,0,6"/>
                    <Border Background="{DynamicResource BrushBgInput}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="Lock" Width="13" Height="13"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="PbxContrasena" Grid.Column="1"
                                         Height="38" BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         FontSize="12" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Botón registrar -->
                    <Button x:Name="BtnRegistrar"
                            Height="42"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnRegistrar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" CornerRadius="8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F26419" Offset="0"/>
                                            <GradientStop Color="#D94F00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <fa:IconImage Icon="UserPlus" Width="14" Height="14"
                                                      Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="REGISTRAR EMPLEADO"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.88"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bg" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
