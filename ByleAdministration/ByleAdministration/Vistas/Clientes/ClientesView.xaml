<UserControl x:Class="ByleAdministration.Vistas.Clientes.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             Background="{DynamicResource BrushBgPrimary}">
    <Grid Margin="24,20,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ COLUMNA IZQUIERDA — lista ══════════ -->
        <DockPanel Grid.Column="0" Margin="0,0,14,0">

            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Buscador -->
                <Border Background="{DynamicResource BrushBgCard}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <fa:IconImage Icon="MagnifyingGlass" Width="13" Height="13"
                                      Foreground="{DynamicResource BrushTextMuted}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtBuscar" Grid.Column="1"
                                 Height="38" BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 CaretBrush="{DynamicResource BrushAccent}"
                                 FontSize="12" VerticalContentAlignment="Center"
                                 TextChanged="TxtBuscar_TextChanged"/>
                        <Button Grid.Column="2" Background="Transparent"
                                BorderThickness="0" Cursor="Hand"
                                VerticalAlignment="Center"
                                Click="BtnLimpiarBusqueda_Click">
                            <fa:IconImage Icon="Xmark" Width="10" Height="10"
                                          Foreground="{DynamicResource BrushTextMuted}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Filtro por estado -->
                <ComboBox x:Name="CmbFiltroEstado"
                          Grid.Column="1" Margin="8,0"
                          Height="38"
                          SelectionChanged="CmbFiltroEstado_SelectionChanged">
                    <ComboBoxItem Content="Todos" IsSelected="True"/>
                    <ComboBoxItem Content="Activos"/>
                    <ComboBoxItem Content="Inactivos"/>
                </ComboBox>

                <!-- Botón nuevo cliente -->
                <Button Grid.Column="2" Height="38"
                        Style="{StaticResource BtnPrimario}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="UserPlus" Width="13" Height="13"
                                      Foreground="White" Margin="0,0,7,0"/>
                        <TextBlock Text="Nuevo cliente" FontSize="12" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Contador -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="TxtContador" Text="0 clientes"
                           FontSize="11"
                           Foreground="{DynamicResource BrushTextMuted}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Encabezado tabla -->
            <Grid DockPanel.Dock="Top"
                  Background="{DynamicResource BrushBgCard}"
                  Height="34" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="CLIENTE" FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="1" Text="TELÉFONO" FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="MEMBRESÍA" FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="ESTADO" FontSize="9" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextMuted}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Lista dinámica -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PanelClientes"/>
            </ScrollViewer>
        </DockPanel>

        <!-- ══════════ COLUMNA DERECHA — perfil ══════════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <!-- Avatar + nombre + estado -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border Width="64" Height="64" CornerRadius="32"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource BrushAccentMuted}"
                                    Margin="0,0,0,10">
                                <TextBlock x:Name="TxtInicialesPerfil" Text="--"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{DynamicResource BrushAccent}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TxtNombrePerfil" Text="Selecciona un cliente"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       HorizontalAlignment="Center"/>
                            <Border x:Name="BorderEstadoPerfil"
                                    Background="#1A3D2B" CornerRadius="8" Padding="10,3"
                                    HorizontalAlignment="Center" Margin="0,6,0,0">
                                <TextBlock x:Name="TxtEstadoPerfil"
                                           Text="● —" FontSize="10" FontWeight="Bold"
                                           Foreground="#2ECC71"/>
                            </Border>
                        </StackPanel>

                        <!-- Datos -->
                        <StackPanel Margin="0,0,0,14">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Teléfono" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtTelefonoPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Correo" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtCorreoPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Membresía" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtMembresiaPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Edad" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtEdadPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ciudad" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtCiudadPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Inscripción" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtInscripcionPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Renovación" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtRenovacionPerfil" Grid.Column="1"
                                           Text="—" FontSize="11"
                                           Foreground="{DynamicResource BrushTextPrimary}"/>
                            </Grid>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{DynamicResource BrushBorder}"
                                   Margin="0,0,0,12"/>

                        <!-- Solo editar -->
                        <Button Content="Editar" Style="{StaticResource BtnSecundario}"
                                FontSize="11" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Nota interna -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <fa:IconImage Icon="NoteSticky" Width="13" Height="13"
                                          Foreground="{DynamicResource BrushTextMuted}"
                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Nota interna" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>
                        <Border Background="{DynamicResource BrushBgInput}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" CornerRadius="8" Padding="10">
                            <TextBox BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     FontSize="11" TextWrapping="Wrap"
                                     AcceptsReturn="True" Height="60"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <Button Content="Guardar nota" Style="{StaticResource BtnSecundario}"
                                FontSize="11" HorizontalAlignment="Right" Margin="0,8,0,0"
                                Padding="12,6"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>