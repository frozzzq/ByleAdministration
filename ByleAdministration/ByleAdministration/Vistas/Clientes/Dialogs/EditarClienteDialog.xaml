<Window x:Class="ByleAdministration.Vistas.Clientes.Dialogs.EditarClienteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Editar Cliente"
        Height="720" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushBgPrimary}">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════ ENCABEZADO ══════════ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Editar cliente"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource BrushAccent}"/>
            <TextBlock x:Name="TxtSubtitulo" Text="ID: —"
                       FontSize="11"
                       Foreground="{DynamicResource BrushTextMuted}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ══════════ CONTENIDO SCROLLABLE ══════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,16">
            <StackPanel>

                <!-- ── DATOS PERSONALES ── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <fa:IconImage Icon="User" Width="14" Height="14"
                                          Foreground="{DynamicResource BrushAccent}"
                                          Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Datos personales" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>

                        <!-- Nombre -->
                        <TextBlock Text="Nombre completo" FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtNombre" Height="36" Padding="10,8"
                                 FontSize="12"
                                 Background="{DynamicResource BrushBgInput}"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 BorderBrush="{DynamicResource BrushBorder}"
                                 CaretBrush="{DynamicResource BrushAccent}"
                                 Margin="0,0,0,10"/>

                        <!-- Edad + Ciudad en fila -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Edad" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtEdad" Height="36" Padding="10,8"
                                         FontSize="12"
                                         Background="{DynamicResource BrushBgInput}"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         BorderBrush="{DynamicResource BrushBorder}"
                                         CaretBrush="{DynamicResource BrushAccent}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ciudad" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtCiudad" Height="36" Padding="10,8"
                                         FontSize="12"
                                         Background="{DynamicResource BrushBgInput}"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         BorderBrush="{DynamicResource BrushBorder}"
                                         CaretBrush="{DynamicResource BrushAccent}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Correo -->
                        <TextBlock Text="Correo" FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtCorreo" Height="36" Padding="10,8"
                                 FontSize="12"
                                 Background="{DynamicResource BrushBgInput}"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 BorderBrush="{DynamicResource BrushBorder}"
                                 CaretBrush="{DynamicResource BrushAccent}"
                                 Margin="0,0,0,10"/>

                        <!-- Teléfonos en fila -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Teléfono" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtTelefono" Height="36" Padding="10,8"
                                         FontSize="12"
                                         Background="{DynamicResource BrushBgInput}"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         BorderBrush="{DynamicResource BrushBorder}"
                                         CaretBrush="{DynamicResource BrushAccent}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Tel. emergencia" FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtTelEmergencia" Height="36" Padding="10,8"
                                         FontSize="12"
                                         Background="{DynamicResource BrushBgInput}"
                                         Foreground="{DynamicResource BrushTextPrimary}"
                                         BorderBrush="{DynamicResource BrushBorder}"
                                         CaretBrush="{DynamicResource BrushAccent}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Estado -->
                        <TextBlock Text="Estado" FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbEstado" Height="36" FontSize="12">
                            <ComboBoxItem Content="activo"/>
                            <ComboBoxItem Content="inactivo"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- ── SENSOR DE HUELLA DIGITAL ── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <fa:IconImage Icon="Fingerprint" Width="14" Height="14"
                                          Foreground="{DynamicResource BrushAccent}"
                                          Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Huella digital — DigitalPersona 4500"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}"/>
                        </StackPanel>

                        <!-- Estado del sensor -->
                        <Border Background="{DynamicResource BrushBgCardHover}"
                                CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Indicador LED -->
                                <Border x:Name="LedSensor" Width="10" Height="10"
                                        CornerRadius="5" Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Background="#E74C3C"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtEstadoSensor"
                                               Text="Sensor no conectado"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <TextBlock x:Name="TxtDetalleSensor"
                                               Text="Conecta el DigitalPersona 4500 por USB"
                                               FontSize="10"
                                               Foreground="{DynamicResource BrushTextMuted}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Área visual de la huella -->
                        <Border Background="{DynamicResource BrushBgInput}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" CornerRadius="10"
                                Height="140" Margin="0,0,0,12">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <fa:IconImage x:Name="IconHuella"
                                              Icon="Fingerprint" Width="48" Height="48"
                                              Foreground="{DynamicResource BrushTextMuted}"/>
                                <TextBlock x:Name="TxtMensajeHuella"
                                           Text="Sin huella registrada"
                                           FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                                <TextBlock x:Name="TxtInstruccionHuella"
                                           Text="Presiona 'Enrolar' para comenzar"
                                           FontSize="10"
                                           Foreground="{DynamicResource BrushTextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Progreso de enrolamiento -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="BarraProgreso"
                                         Height="6" Minimum="0" Maximum="4" Value="0"
                                         Background="{DynamicResource BrushBgInput}"
                                         Foreground="{DynamicResource BrushAccent}"
                                         BorderThickness="0"/>
                            <TextBlock x:Name="TxtProgreso" Grid.Column="1"
                                       Text="0 / 4 capturas"
                                       FontSize="10"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Log de eventos del sensor -->
                        <TextBlock Text="Registro de eventos" FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,4"/>
                        <Border Background="{DynamicResource BrushBgInput}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="8" Height="70">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TxtLogSensor"
                                           Text="[Sistema] Esperando conexión del sensor..."
                                           FontSize="10" FontFamily="Consolas"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Botones de huella -->
                        <UniformGrid Columns="3" Rows="1" Margin="0,12,0,0">
                            <Button x:Name="BtnEnrolar" Content="Enrolar"
                                    Style="{StaticResource BtnPrimario}"
                                    FontSize="11" Margin="0,0,4,0"
                                    />
                            <Button x:Name="BtnVerificar" Content="Verificar"
                                    Style="{StaticResource BtnSecundario}"
                                    FontSize="11" Margin="2,0"
                                    />
                            <Button x:Name="BtnEliminarHuella" Content="Eliminar"
                                    FontSize="11" Margin="4,0,0,0"
                                    Foreground="{DynamicResource BrushError}"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource BrushError}"
                                    BorderThickness="1" Cursor="Hand"
                                    />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ══════════ BOTONES INFERIORES ══════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Cancelar"
                    Style="{StaticResource BtnSecundario}"
                    FontSize="12" Margin="0,0,8,0"
                    Padding="20,10"
                    />
            <Button Grid.Column="2" Content="Guardar cambios"
                    Style="{StaticResource BtnPrimario}"
                    FontSize="12"
                    Padding="20,10"
                    />
        </Grid>
    </Grid>
</Window>