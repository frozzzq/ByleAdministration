<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fondos base -->
    <Color x:Key="primaryBackColor1">#0D0D1B</Color>
    <Color x:Key="primaryBackColor2">#14142A</Color>
    <Color x:Key="secondaryBackColor1">#0A0A18</Color>
    <Color x:Key="secondaryBackColor2">#111128</Color>

    <!-- Bordes ventana -->
    <Color x:Key="winBorderColor1">#F26419</Color>
    <Color x:Key="winBorderColor2">#2A2A55</Color>
    <Color x:Key="winBorderColor3">#0D0D1B</Color>

    <!-- Nav -->
    <Color x:Key="panelActiveColor">#1E1E3A</Color>
    <Color x:Key="panelOverColor">#16163A</Color>

    <!-- Textos -->
    <Color x:Key="plainTextColor3">#7070A0</Color>
    <Color x:Key="titleColor2">#F0F0F5</Color>
    <Color x:Key="titleColor3">#F0F0F5</Color>

    <!-- Colores de acento por sección -->
    <Color x:Key="color1">#F26419</Color>
    <Color x:Key="color2">#F26419</Color>
    <Color x:Key="color3">#F26419</Color>
    <Color x:Key="color4">#F26419</Color>
    <Color x:Key="color5">#F26419</Color>
    <Color x:Key="color6">#F26419</Color>
    <Color x:Key="color7">#F26419</Color>
    <Color x:Key="color8">#F26419</Color>

    <!-- Brushes funcionales -->
    <SolidColorBrush x:Key="BrushBgPrimary"      Color="{StaticResource primaryBackColor1}"/>
    <SolidColorBrush x:Key="BrushBgSidebar"      Color="{StaticResource secondaryBackColor1}"/>
    <SolidColorBrush x:Key="BrushBgCard"         Color="#1A1A35"/>
    <SolidColorBrush x:Key="BrushBgCardHover"    Color="#22223F"/>
    <SolidColorBrush x:Key="BrushBgInput"        Color="#1E1E3A"/>
    <SolidColorBrush x:Key="BrushAccent"         Color="#F26419"/>
    <SolidColorBrush x:Key="BrushAccentHover"    Color="#FF7A2F"/>
    <SolidColorBrush x:Key="BrushAccentMuted"    Color="#3D2010"/>
    <SolidColorBrush x:Key="BrushTextPrimary"    Color="#F0F0F5"/>
    <SolidColorBrush x:Key="BrushTextSecondary"  Color="#7070A0"/>
    <SolidColorBrush x:Key="BrushTextMuted"      Color="#44445A"/>
    <SolidColorBrush x:Key="BrushBorder"         Color="#2A2A48"/>
    <SolidColorBrush x:Key="BrushNavSelected"    Color="#1E1E3A"/>
    <SolidColorBrush x:Key="BrushNavHover"       Color="#16163A"/>
    <SolidColorBrush x:Key="BrushSuccess"        Color="#2ECC71"/>
    <SolidColorBrush x:Key="BrushError"          Color="#E74C3C"/>
    <SolidColorBrush x:Key="BrushWarning"        Color="#F39C12"/>
</ResourceDictionary>