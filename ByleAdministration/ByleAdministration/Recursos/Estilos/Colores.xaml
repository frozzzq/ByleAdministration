<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ColorOscuro">#1A1A2E</Color>
    <Color x:Key="ColorNaranja">#E05C00</Color>
    <Color x:Key="ColorGris">#2E2E3A</Color>
    <Color x:Key="ColorTextoClaro">#F0F0F0</Color>
    <Color x:Key="ColorError">#FF8B3D</Color>

    <SolidColorBrush x:Key="BrushOscuro"     Color="{StaticResource ColorOscuro}"/>
    <SolidColorBrush x:Key="BrushNaranja"    Color="{StaticResource ColorNaranja}"/>
    <SolidColorBrush x:Key="BrushGris"       Color="{StaticResource ColorGris}"/>
    <SolidColorBrush x:Key="BrushTextoClaro" Color="{StaticResource ColorTextoClaro}"/>
    <SolidColorBrush x:Key="BrushError"      Color="{StaticResource ColorError}"/>

</ResourceDictionary>