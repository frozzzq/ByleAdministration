<Window x:Class="ByleAdministration.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="ByleAdministration" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="12" BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.5"/>
                <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.8">
                        <GradientStop Color="{StaticResource secondaryBackColor1}" Offset="0"/>
                        <GradientStop Color="{StaticResource secondaryBackColor2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <DockPanel>
                    <!-- Logo -->
                    <StackPanel DockPanel.Dock="Top" Margin="24,28,0,24">
                        <TextBlock Text="BYLE" FontSize="26" FontWeight="Black"
                                   Foreground="{DynamicResource BrushAccent}"/>
                        <TextBlock Text="Administration" FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   Margin="2,3,0,0"/>
                    </StackPanel>

                    <Rectangle DockPanel.Dock="Top" Height="1" Margin="16,0,16,8">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#2A2A48" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="14,14">
                        <Rectangle Height="1" Margin="0,0,0,12">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#2A2A48" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <ToggleButton x:Name="ThemeToggle"
                                      Style="{StaticResource ThemeToggleStyle}"
                                      Click="ThemeToggle_Click"
                                      HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ThemeIcon" Text="☀" FontSize="13"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                                <TextBlock x:Name="ThemeLabel" Text="Modo claro" FontSize="12"
                                           Foreground="{DynamicResource BrushTextSecondary}"/>
                            </StackPanel>
                        </ToggleButton>

                        <Border Margin="0,10,0,0" CornerRadius="10" Padding="12,10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A35" Offset="0"/>
                                    <GradientStop Color="#22223F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="17">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F26419" Offset="0"/>
                                            <GradientStop Color="#D94F00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="A" FontSize="14" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtUsuarioActivo" Text="Admin"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                    <TextBlock Text="Administrador" FontSize="10"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- NAVEGACIÓN — x:Name es la clave para identificar secciones -->
                    <StackPanel DockPanel.Dock="Top">

                        <RadioButton x:Name="NavDashboard"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color1}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ChartPie" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Dashboard" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavAcceso"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color2}"
                                     GroupName="Nav"
                                     IsChecked="True"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="DoorOpen" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Acceso" Style="{StaticResource menuButtonText}"/>
                                <Border Background="{DynamicResource BrushAccent}" CornerRadius="8"
                                        Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="★" FontSize="9" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavVentas"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color3}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="CashRegister" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Ventas / Caja" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavClientes"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color4}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Users" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Clientes" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavMembresias"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color5}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="IdCard" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Membresías" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavClases"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color6}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="PersonRunning" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Clases y Progreso" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavReportes"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color7}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ChartBar" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Reportes" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavSistema"
                                     Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color8}"
                                     GroupName="Nav"
                                     Click="NavBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Gear" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Sistema" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ÁREA PRINCIPAL -->
            <Border Grid.Column="1" CornerRadius="0,12,12,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                        <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0"/>
                        <GradientStop Color="{StaticResource primaryBackColor2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra control -->
                    <StackPanel Grid.Row="0"
                                x:Name="pnlControlBar"
                                Orientation="Horizontal"
                                FlowDirection="RightToLeft"
                                Background="Transparent"
                                Margin="0,4,8,0"
                                MouseLeftButtonDown="pnlControlBar_MouseLeftButtonDown">
                        <Button Style="{StaticResource controlButton}" Click="BtnCerrar_Click">
                            <fa:IconImage Icon="Xmark" Width="12" Height="12"
                                          Foreground="{DynamicResource BrushTextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource controlButton}" Click="BtnMinimizar_Click">
                            <fa:IconImage Icon="WindowMinimize" Width="12" Height="12"
                                          Foreground="{DynamicResource BrushTextSecondary}"/>
                        </Button>
                    </StackPanel>

                    <!-- Topbar -->
                    <Border Grid.Row="1" Padding="28,0"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="0,0,0,1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D0D1B" Offset="0"/>
                                <GradientStop Color="#14142A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <TextBlock x:Name="TxtSeccionActual" Text="Acceso"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        DockPanel.Dock="Right">
                                <TextBox Style="{StaticResource SearchBoxStyle}"
                                         Width="220" Height="36"
                                         Foreground="{DynamicResource BrushTextMuted}"
                                         Text="Buscar..."/>
                                <Border Width="36" Height="36" CornerRadius="18"
                                        Cursor="Hand" Margin="10,0,0,0"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A35" Offset="0"/>
                                            <GradientStop Color="#22223F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <fa:IconImage Icon="Bell" Width="15" Height="15"
                                                  Foreground="{DynamicResource BrushTextSecondary}"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Contenido dinámico -->
                    <ContentControl x:Name="MainContent" Grid.Row="2"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
    </Window>