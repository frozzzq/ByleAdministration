<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head', { pageTitle: 'Configurar acceso web' }) %></head>
<body>
  <%- include('../partials/navbar') %>
  <div class="auth-wrapper">
    <div class="auth-box">
      <div class="auth-header">
        <h1 class="text-h2">Configura tu acceso web</h1>
        <p class="text-body mt-xs">Si ya eres socio, crea tu contraseña web con el correo que registraste en la sucursal</p>
      </div>
      <!-- TODO: POST /api/auth/registro → busca correo en tabla usuarios, si existe crea registro en usuario_web -->
      <form onsubmit="event.preventDefault(); alert('Cuenta creada. Ahora puedes iniciar sesión.'); window.location='/login'">
        <div class="form-group">
          <label class="form-label">Correo registrado en sucursal</label>
          <input type="email" class="form-input" placeholder="tu@correo.com" required>
          <p class="form-hint">Debe coincidir con el correo que diste al inscribirte</p>
        </div>
        <div class="form-group">
          <label class="form-label">Crea tu contraseña web</label>
          <input type="password" class="form-input" placeholder="Mínimo 8 caracteres" required>
        </div>
        <div class="form-group">
          <label class="form-label">Confirma tu contraseña</label>
          <input type="password" class="form-input" placeholder="Repite la contraseña" required>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg mt-md">Crear acceso web</button>
      </form>
      <p class="text-center mt-lg text-small">¿Ya tienes acceso? <a href="/login">Inicia sesión</a></p>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
