<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { pageTitle: 'Mis Pagos' }) %>
</head>
<body>
  <div class="page-wrapper">
    <%- include('partials/navbar') %>

    <main class="page-content">

      <div class="page-header">
        <h1 class="text-h1">Historial de pagos</h1>
        <p class="text-body">Tus transacciones y compras</p>
      </div>

      <!-- Resumen -->
      <div class="stats-grid" style="grid-template-columns: 1fr 1fr;">
        <div class="stat-card">
          <div class="stat-value" style="color:var(--accent)">$899</div>
          <div class="stat-label">Último pago</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:var(--success)">Al día</div>
          <div class="stat-label">Estado</div>
        </div>
      </div>

      <!-- Lista de pagos -->
      <div class="section-title">Últimos movimientos</div>
      <div class="card">

        <div class="list-item" style="border-bottom:1px solid var(--border)">
          <div class="list-icon">
            <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <div class="list-content">
            <div class="list-title">Membresía Premium Plus</div>
            <div class="list-subtitle">15 Mar 2026 · Renovación</div>
          </div>
          <div class="list-right">
            <div class="text-h3">$899</div>
            <div class="text-caption text-success">Pagado</div>
          </div>
        </div>

        <div class="list-item" style="border-bottom:1px solid var(--border)">
          <div class="list-icon">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div class="list-content">
            <div class="list-title">Inscripción Spinning</div>
            <div class="list-subtitle">12 Mar 2026 · Clase grupal</div>
          </div>
          <div class="list-right">
            <div class="text-h3">$150</div>
            <div class="text-caption text-success">Pagado</div>
          </div>
        </div>

        <div class="list-item" style="border-bottom:1px solid var(--border)">
          <div class="list-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12l3-3 3 3"/><path d="M12 15V9"/></svg>
          </div>
          <div class="list-content">
            <div class="list-title">Proteína Whey 1kg</div>
            <div class="list-subtitle">8 Mar 2026 · Producto</div>
          </div>
          <div class="list-right">
            <div class="text-h3">$450</div>
            <div class="text-caption text-success">Pagado</div>
          </div>
        </div>

        <div class="list-item" style="border-bottom:1px solid var(--border)">
          <div class="list-icon">
            <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <div class="list-content">
            <div class="list-title">Membresía Premium Plus</div>
            <div class="list-subtitle">15 Feb 2026 · Renovación</div>
          </div>
          <div class="list-right">
            <div class="text-h3">$899</div>
            <div class="text-caption text-success">Pagado</div>
          </div>
        </div>

        <div class="list-item">
          <div class="list-icon">
            <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <div class="list-content">
            <div class="list-title">Membresía Premium Plus</div>
            <div class="list-subtitle">15 Ene 2026 · Primera inscripción</div>
          </div>
          <div class="list-right">
            <div class="text-h3">$899</div>
            <div class="text-caption text-success">Pagado</div>
          </div>
        </div>

      </div>

    </main>

    <%- include('partials/bottomNav') %>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
